{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "types": [
            "react",
            "react-dom",
            "@react-three/fiber"
        ],
        "target": "ES2017",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "module": "esnext",
        "moduleResolution": "node",
        "baseUrl": ".",
        "skipLibCheck": true
    },
    "include": [
        "src"
    ]
}
